generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TokenStatus {
  PENDING
  FILTER_PASSED
  FILTER_FAILED
  RISK_PASSED
  RISK_FAILED
}

model Token {
  id        String     @id @default(uuid())
  address   String     @unique
  symbol    String?
  name      String?
  decimals  Int?
  liquidity Float?
  volume24h Float?
  status    TokenStatus @default(PENDING)
  createdAt DateTime   @default(now())

  @@index([address])
  @@index([status])
}

enum PendingTradeStatus {
  QUEUED
  PROCESSING
  EXECUTED
  FAILED
}

model PendingTrade {
  id           String             @id @default(uuid())
  tokenAddress String
  status       PendingTradeStatus @default(QUEUED)
  riskScore    Float
  createdAt    DateTime           @default(now())

  @@index([tokenAddress])
  @@index([status])
}

model Discovery {
  id             String   @id @default(uuid())
  tokenAddress    String
  mint           String
  liquidity       Float
  timestamp       DateTime @default(now())
  reason          String?  // Reason for skipping/rejection (e.g., "Slippage", "Filter Failed")
  source          String   @default("SNIPER") // Source: "SNIPER" or "SCOUT"
  momentumRatio    Float?  // Volume-to-liquidity ratio from MomentumFilter
  whaleScore       Int     @default(0) // Future Whale Watcher plugin

  @@index([tokenAddress])
  @@index([timestamp])
  @@index([source])
}

model Whitelist {
  id        String   @id @default(uuid())
  mint      String   @unique
  symbol    String?
  addedAt   DateTime @default(now())

  @@index([mint])
}

model Preset {
  id     String @id
  name   String
  config Json
  jitoTipSol Float? @default(0.001)
}

enum PaperTradeStatus {
  OPEN
  CLOSED
}

model PaperTrade {
  id           String           @id @default(uuid())
  tokenAddress String
  amount       Float
  entryPrice   Float
  exitPrice    Float?
  exitReason   String?
  didTakeInitialProfit Boolean @default(false)
  remainingAmount Float?
  status       PaperTradeStatus @default(OPEN)
  createdAt    DateTime         @default(now())

  @@index([tokenAddress])
  @@index([status])
}
